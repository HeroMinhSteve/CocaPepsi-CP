{
  "manifest_version": 3,
  "name": "CocaPepsi CP",
  "version": "3.0.4",
  "description": "Helper Extension for Competitive Programming",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "force-submit": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Force Submit on QOJ"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.codeforces.com/*"
      ],
      "js": [
        "Codeforces.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://qoj.ac/*"
      ],
      "js": [
        "QOJ.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://atcoder.jp/*",
        "*://*.atcoder.jp/*"
      ],
      "js": [
        "AtCoder.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://oj.uz/*",
        "*://*.oj.uz/*"
      ],
      "js": [
        "OJUZ.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://dmoj.ca/*",
        "*://*.dmoj.ca/*",
        "*://oj.vnoi.info/*",
        "*://*.oj.vnoi.info/*",
        "*://qhhoj.com/*",
        "*://*.qhhoj.com/*",
        "*://oj.clue.edu.vn/*",
        "*://*.oj.clue.edu.vn/*",
        "*://hnoj.edu.vn/*",
        "*://*.hnoj.edu.vn/*"
      ],
      "js": [
        "DMOJ.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://cses.fi/*"
      ],
      "js": [
        "cses.js"
      ]
    }
  ],
  "permissions": [],
  "icons": {
    "16": "icons/icon16x16.png",
    "48": "icons/icon48x48.png",
    "128": "icons/icon128x128.png"
  }
}