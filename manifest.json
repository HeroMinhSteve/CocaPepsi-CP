{
  "manifest_version": 3,
  "name": "CocaPepsi CF",
  "version": "2.2.2",
  "description": "Helper Extension for Competitive Programming",
  "content_scripts": [
    {
      "matches": [
        "*://*.codeforces.com/*"
      ],
      "js": [
        "Codeforces.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://qoj.ac/*"
      ],
      "js": [
        "QOJ.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "icons": {
    "16": "icons/icon16x16.png",
    "48": "icons/icon48x48.png",
    "128": "icons/icon128x128.png"
  }
}